# StadiumAI NOC Backend — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# Neo4j AuraDB
NEO4J_URI=bolt+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Gemini API
GEMINI_API_KEY=

# GCP
GCP_PROJECT=stadiumai-project

# Redis (Memorystore)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# Auth / JWT (for staff access control)
JWT_SECRET=your_jwt_secret_key_here
DEMO_ACCOUNT_USERNAME=noc_operator
DEMO_ACCOUNT_PASSWORD_HASH=your_bcrypt_hash_for_operator_password_here
